"""
Sidebar Widget
Astro Research Lab
"""

from PySide6.QtCore import Qt
from PySide6.QtWidgets import (
    QFrame,
    QLabel,
    QPushButton,
    QSizePolicy,
    QVBoxLayout,
)


class Sidebar(QFrame):
    """
    Left navigation sidebar.
    """

    def __init__(self):
        super().__init__()

        self.setObjectName("Sidebar")

        self.initialize_ui()

    def initialize_ui(self):
        """
        Build sidebar layout.
        """

        self.setFixedWidth(260)

        self.setFrameShape(QFrame.NoFrame)

        self.setSizePolicy(
            QSizePolicy.Fixed,
            QSizePolicy.Expanding,
        )

        layout = QVBoxLayout()

        layout.setContentsMargins(20, 20, 20, 20)

        layout.setSpacing(12)

        self.setLayout(layout)

        # ---------------------------------------------------
        # Logo / Title
        # ---------------------------------------------------

        title = QLabel("Astro Research Lab")

        title.setAlignment(Qt.AlignCenter)

        title.setStyleSheet("""
            QLabel {
                font-size:20px;
                font-weight:bold;
                color:#ffffff;
                padding:15px;
            }
        """)

        layout.addWidget(title)

        # ---------------------------------------------------
        # Navigation Buttons
        # ---------------------------------------------------

        menu_items = [
            "Dashboard",
            "Horoscopes",
            "Research",
            "Events",
            "Analytics",
            "Reports",
            "Settings",
        ]

        for text in menu_items:

            button = QPushButton(text)

            button.setMinimumHeight(42)

            button.setCursor(Qt.PointingHandCursor)

            button.setStyleSheet("""
                QPushButton{
                    background:#2d3748;
                    color:white;
                    border:none;
                    border-radius:8px;
                    padding-left:15px;
                    text-align:left;
                    font-size:14px;
                }

                QPushButton:hover{
                    background:#4a5568;
                }

                QPushButton:pressed{
                    background:#1a202c;
                }
            """)

            layout.addWidget(button)

        layout.addStretch()

        # ---------------------------------------------------
        # Footer
        # ---------------------------------------------------

        version = QLabel("Version 0.0.1")

        version.setAlignment(Qt.AlignCenter)

        version.setStyleSheet("""
            QLabel{
                color:#999999;
                font-size:11px;
                padding:10px;
            }
        """)

        layout.addWidget(version)

        # ---------------------------------------------------
        # Sidebar Background
        # ---------------------------------------------------

        self.setStyleSheet("""
            QFrame#Sidebar{
                background:#1f2937;
            }
        """)