"""
Astro Research Lab
Application Entry Point
"""
from app.database.database import DatabaseManager
import sys
import traceback

from PySide6.QtWidgets import QApplication, QMessageBox

from app.config.settings import APP_NAME, APP_VERSION
from app.ui.windows.main_window import MainWindow


def exception_hook(exc_type, exc_value, exc_tb):
    """
    Global exception handler.
    Displays unexpected exceptions instead of silently crashing.
    """

    traceback_text = "".join(
        traceback.format_exception(exc_type, exc_value, exc_tb)
    )

    print(traceback_text)

    QMessageBox.critical(
        None,
        "Unexpected Error",
        traceback_text,
    )


def create_application() -> QApplication:
    """
    Create and configure QApplication.
    """

    app = QApplication(sys.argv)

    app.setApplicationName(APP_NAME)
    app.setApplicationVersion(APP_VERSION)
    app.setOrganizationName("Astro Research Lab")
    app.setOrganizationDomain("local")

    return app


def main() -> int:
    """
    Main application startup.
    """
    print("1. Starting application")

    sys.excepthook = exception_hook

    print("2. Initializing database")
    DatabaseManager.initialize()

    print("3. Creating QApplication")
    app = create_application()

    print("4. Creating MainWindow")
    window = MainWindow()

    print("5. Showing MainWindow")
    window.show()
    window.show()

    print("Visible :", window.isVisible())
    print("Hidden  :", window.isHidden())
    print("Size    :", window.size())
    print("Geometry:", window.geometry())
    print("Geometry:", window.geometry())
    print("6. Entering Qt Event Loop")

    return app.exec()
    print("Qt exited with:", result)

    return result
    sys.excepthook = exception_hook

    # --------------------------------------------------
    # Initialize Database
    # --------------------------------------------------

    DatabaseManager.initialize()

    # --------------------------------------------------
    # Create Qt Application
    # --------------------------------------------------

    app = create_application()

    # --------------------------------------------------
    # Open Main Window
    # --------------------------------------------------

    window = MainWindow()

    window.show()

    # --------------------------------------------------
    # Start Event Loop
    # --------------------------------------------------

    return app.exec()


if __name__ == "__main__":
    raise SystemExit(main())